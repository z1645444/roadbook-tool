{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roadbook-tool.local/schema/05-output.schema.json",
  "title": "Phase 5 Address and QR Output",
  "$comment": "OUT-01 OUT-02 OUT-03 OUT-04; no_live_request no_message_send no_qr_image",
  "type": "object",
  "required": [
    "route_summary",
    "address",
    "eta",
    "notes",
    "qr",
    "output_views",
    "metadata"
  ],
  "additionalProperties": false,
  "properties": {
    "route_summary": {
      "type": "string",
      "minLength": 1
    },
    "address": {
      "type": "object",
      "required": ["primary_link", "segment_links"],
      "additionalProperties": false,
      "properties": {
        "primary_link": {
          "type": "string",
          "pattern": "^https://uri\\.amap\\.com/"
        },
        "segment_links": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^https://uri\\.amap\\.com/"
          }
        }
      }
    },
    "eta": {
      "type": "object",
      "required": ["total", "is_estimated"],
      "additionalProperties": false,
      "properties": {
        "total": {
          "type": "string",
          "minLength": 1
        },
        "is_estimated": {
          "type": "boolean",
          "const": true
        },
        "per_segment": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["segment_index", "duration_note"],
            "additionalProperties": false,
            "properties": {
              "segment_index": {
                "type": "integer",
                "minimum": 1
              },
              "duration_note": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "notes": {
      "type": "object",
      "required": ["text"],
      "additionalProperties": false,
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "degrade_reason": {
          "type": "string"
        }
      }
    },
    "qr": {
      "type": "object",
      "required": [
        "status",
        "payload_equals_primary_link",
        "consistency_check_method"
      ],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["available", "unavailable", "not_requested"]
        },
        "payload_text": {
          "type": "string"
        },
        "payload_equals_primary_link": {
          "type": "boolean"
        },
        "consistency_check_method": {
          "type": "string",
          "const": "utf8_byte_compare"
        }
      }
    },
    "output_views": {
      "type": "object",
      "required": ["human_primary", "ag_sections"],
      "additionalProperties": false,
      "properties": {
        "human_primary": {
          "type": "string",
          "minLength": 1
        },
        "ag_sections": {
          "type": "object",
          "required": ["A", "B", "C", "D", "E", "F", "G"],
          "additionalProperties": false,
          "properties": {
            "A": {"type": "string", "minLength": 1},
            "B": {"type": "string", "minLength": 1},
            "C": {"type": "string", "minLength": 1},
            "D": {"type": "string", "minLength": 1},
            "E": {"type": "string", "minLength": 1},
            "F": {"type": "string", "minLength": 1},
            "G": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": [
        "version",
        "created_at",
        "no_live_request",
        "no_message_send",
        "no_qr_image",
        "requirements_map"
      ],
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "no_live_request": {
          "type": "boolean",
          "const": true
        },
        "no_message_send": {
          "type": "boolean",
          "const": true
        },
        "no_qr_image": {
          "type": "boolean",
          "const": true
        },
        "requirements_map": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "string",
            "enum": ["OUT-01", "OUT-02", "OUT-03", "OUT-04"]
          },
          "uniqueItems": true
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "qr": {
            "properties": {
              "status": {"const": "available"}
            },
            "required": ["status"]
          }
        }
      },
      "then": {
        "properties": {
          "qr": {
            "required": ["payload_text", "payload_equals_primary_link"],
            "properties": {
              "payload_equals_primary_link": {"const": true}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "qr": {
            "properties": {
              "status": {"const": "unavailable"}
            },
            "required": ["status"]
          }
        }
      },
      "then": {
        "properties": {
          "notes": {
            "required": ["degrade_reason"],
            "properties": {
              "degrade_reason": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    }
  ]
}
