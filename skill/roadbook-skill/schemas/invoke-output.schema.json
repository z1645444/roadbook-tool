{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "roadbook-skill.invoke-output",
  "title": "roadbook.plan output",
  "type": "object",
  "required": [
    "ok",
    "status",
    "data"
  ],
  "properties": {
    "ok": {
      "type": "boolean",
      "const": true
    },
    "status": {
      "type": "string",
      "enum": [
        "ready",
        "needs_clarification",
        "fallback"
      ]
    },
    "data": {
      "type": "object",
      "description": "Roadbook skill result payload."
    }
  },
  "additionalProperties": false
}

