{
  "name": "roadbook-tool",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env --import tsx src/main.ts",
    "test": "vitest run",
    "test:conversation": "vitest run tests/conversation",
    "test:phase1": "vitest run tests/conversation tests/constraints tests/recap"
  },
  "dependencies": {
    "@nestjs/common": "11.1.19",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-fastify": "11.1.19",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "fastify": "5.8.5",
    "luxon": "3.7.2",
    "reflect-metadata": "0.2.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "24.9.0",
    "tsx": "4.20.6",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  }
}
